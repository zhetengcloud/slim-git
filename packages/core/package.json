{
  "name": "@slim-git/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "bun": "./src/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@slim-git/types": "workspace:*",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@slim-git/memory": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
