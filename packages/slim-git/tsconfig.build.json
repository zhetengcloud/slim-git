{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "paths": {
      "@slim-git/types": ["../types/dist/index.d.ts"],
      "@slim-git/core": ["../core/dist/index.d.ts"],
      "@slim-git/memory": ["../memory/dist/index.d.ts"],
      "@slim-git/fs": ["../fs/dist/index.d.ts"],
      "@slim-git/http": ["../http/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "test/**/*.ts"]
}
