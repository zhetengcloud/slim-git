{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@slim-git/types": ["./packages/types/src/index.ts"],
      "@slim-git/core": ["./packages/core/src/index.ts"],
      "@slim-git/core/*.js": ["./packages/core/src/*.ts"],
      "@slim-git/memory": ["./packages/memory/src/index.ts"],
      "@slim-git/http": ["./packages/http/src/index.ts"],
      "@slim-git/fs": ["./packages/fs/src/index.ts"],
      "slim-git": ["./packages/slim-git/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "packages/@slim-git/*/src/**/*.ts",
    "packages/@slim-git/*/test/**/*.ts"
  ]
}
